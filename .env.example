# ──────────────────────────────────────────────────────────────────────────────
# FlixMate — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma Client.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/flixmate?schema=public"

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# API key for Gemini AI integrations (optional — reserved for future AI features).
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Application ───────────────────────────────────────────────────────────────
# Base URL where the frontend is hosted (used for CORS and OAuth callbacks).
APP_URL="http://localhost:3000"

# Port for the Express backend API server.
PORT=4000

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV="development"
