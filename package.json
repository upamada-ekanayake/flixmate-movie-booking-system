{
  "name": "flixmate",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered movie booking and recommendation platform built with React, TypeScript, Prisma, and PostgreSQL.",
  "author": "Upe",
  "license": "MIT",
  "homepage": "https://github.com/upe/flixmate-movie-booking-system",
  "repository": {
    "type": "git",
    "url": "https://github.com/upe/flixmate-movie-booking-system.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:backend": "esbuild backend/src/server.ts --bundle --platform=node --outfile=dist-backend/server.js --format=esm --packages=external",
    "start:backend": "node dist-backend/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-backend server.js",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
